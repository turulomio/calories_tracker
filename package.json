{
  "name": "calories_tracker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "translate": "vue-i18n-extract --vueFiles './src/**/*.?(js|vue)' --languageFiles './src/locales/**/*.json' --add true --remove true --separator '###' ",
    "eslint": "eslint . --fix --ignore-pattern .gitignore --ignore-pattern output --ignore-pattern dist",
    "reusing": "node src/scripts/reusing.js",
    "vitest": "vitest --passWithNoTests",
    "playwright": "playwright test --ui --output output/playwright",
    "playwright_console": "playwright test --output output/playwright",
    "playwright_coverage": "nyc --reporter=lcov --report-dir  output/coverage  playwright test"
  },
  "dependencies": {
    "@mdi/font": "7.4.47",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-mention": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/suggestion": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "axios": "^1.15.0",
    "echarts": "^6.0.0",
    "flag-icons": "^7.5.0",
    "fraction.js": "^5.3.4",
    "html-to-pdfmake": "^2.5.33",
    "pdfmake": "^0.3.7",
    "pinia": "^3.0.4",
    "roboto-fontface": "*",
    "tippy.js": "^6.3.7",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.5",
    "vuetify_rules": "^0.7.0",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^10.2.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "npm-check-updates": "^20.0.1",
    "nyc": "^18.0.0",
    "playwright": "^1.59.1",
    "vite": "^8.0.8",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-istanbul": "^8.0.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.4",
    "vue-i18n-extract": "github:Spittal/vue-i18n-extract"
  }
}
